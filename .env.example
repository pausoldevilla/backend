# ─── Variables d'entorn del projecte ─────────────────────────────────────────
# IMPORTANT: Aquest fitxer NO s'ha de pujar a GitHub!
# Afegeix-lo al .gitignore del projecte.
# Copia aquest fitxer com a .env i emplena els valors reals.

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=root
MONGO_PASSWORD=password

# ── JWT (JSON Web Tokens) ─────────────────────────────────────────────────────
JWT_SECRET=super-secret-key
JWT_REFRESH_SECRET=super-refresh-secret-key

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
EMAIL_USER=info.soldevilla@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Stripe (pagaments) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── URL del client (frontend) ─────────────────────────────────────────────────
# Dev:  http://localhost:5173
# Prod: http://localhost o el vostre domini
CLIENT_URL=http://localhost
